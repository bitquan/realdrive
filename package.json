{
  "name": "realdrive",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "zod": "^3.24.2"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @realdrive/api --filter @realdrive/web dev",
    "dev:api": "pnpm --filter @realdrive/api dev",
    "dev:web": "pnpm --filter @realdrive/web dev",
    "dev:auto-pricing-worker": "pnpm --filter @realdrive/api dev:worker:auto-pricing",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "ops:health": "node scripts/ops/health-check.mjs",
    "ops:digest": "node scripts/ops/daily-digest.mjs",
    "ops:labels": "node scripts/ops/setup-labels.mjs",
    "sms:test": "node scripts/ops/sms-test.mjs",
    "sms:test:virtual": "SMS_TEST_TO=+18777804236 node scripts/ops/sms-test.mjs",
    "sms:test:raw": "node scripts/ops/sms-test.mjs",
    "sms:test:ride": "node scripts/ops/sms-test.mjs",
    "db:generate": "pnpm --filter @realdrive/api prisma:generate",
    "db:migrate": "pnpm --filter @realdrive/api prisma:migrate",
    "db:seed": "pnpm --filter @realdrive/api prisma:seed"
  }
}
