{
  "name": "realdrive",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "zod": "^3.24.2"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @realdrive/api --filter @realdrive/web dev",
    "dev:api": "pnpm --filter @realdrive/api dev",
    "dev:web": "pnpm --filter @realdrive/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @realdrive/api prisma:generate",
    "db:migrate": "pnpm --filter @realdrive/api prisma:migrate",
    "db:seed": "pnpm --filter @realdrive/api prisma:seed"
  }
}
